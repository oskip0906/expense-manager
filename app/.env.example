# ---------------------------------------------------------------------------
# Copy to `app/.env` (git-ignored). Expo loads EXPO_PUBLIC_* into the client
# bundle at build time. These are client-safe values only — NOTHING secret goes
# here (Plaid/Gemini keys live in Firebase secrets, set via the Firebase CLI).
# See the root .env.example for the full picture and SETUP.md for where each
# value comes from.
# ---------------------------------------------------------------------------

# === Firebase (client — safe to ship in the app; not secret) ===
# From Firebase console > Project settings > Your apps (Web app config).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# === Google Sign-In (client) ===
# OAuth client IDs from Google Cloud console. webClientId is the one Firebase
# uses to mint the ID token; iOS needs its own client id too.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Reversed iOS client id (the REVERSED_CLIENT_ID from GoogleService-Info.plist),
# e.g. com.googleusercontent.apps.1234567890-abcdef. Used by the Google Sign-In
# config plugin's iosUrlScheme during prebuild.
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# === EAS ===
# EAS project id (also used by expo-notifications to mint push tokens).
EXPO_PUBLIC_EAS_PROJECT_ID=

# === Cloud Functions ===
# Region the callable Functions are deployed to. Must match functions/ config.
EXPO_PUBLIC_FUNCTIONS_REGION=us-central1
