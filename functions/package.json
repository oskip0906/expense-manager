{
  "name": "functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build:shared": "npm --prefix .. run build:shared",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=lib/index.js --external:firebase-functions --external:firebase-admin --external:plaid --external:@google/genai --external:expo-server-sdk --external:zod",
    "build": "npm run build:shared && npm run typecheck && npm run bundle",
    "typecheck": "tsc --noEmit",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "pipeline:local": "tsx src/pipeline/local.ts"
  },
  "dependencies": {
    "@google/genai": "^2.0.0",
    "expo-server-sdk": "^3.10.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0",
    "plaid": "^27.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@expense/shared": "file:../packages/shared",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
