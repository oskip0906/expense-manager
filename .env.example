# ---------------------------------------------------------------------------
# Copy to `.env` files as noted below. NEVER commit real values.
# Config is read by two runtimes (the nightly pipeline is now a scheduled Cloud
# Function, so there is NO GitHub Actions secret / service-account key):
#   - app/          -> app.config.ts reads EXPO_PUBLIC_* from app/.env
#   - functions/    -> Firebase params + secrets (firebase functions:secrets:set);
#                      non-secret params via functions/.env
# ---------------------------------------------------------------------------

# === Firebase (client — safe to ship in the app; not secret) ===
# From Firebase console > Project settings > Your apps (Web app config).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# === Google Sign-In (client) ===
# OAuth client IDs from Google Cloud console. webClientId is the one Firebase
# uses to mint the ID token; iOS needs its own client id too.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# EAS project id (for expo-notifications push tokens)
EXPO_PUBLIC_EAS_PROJECT_ID=

# === Plaid (SERVER ONLY — Cloud Functions) ===
# Secrets: set with `firebase functions:secrets:set PLAID_CLIENT_ID` (and PLAID_SECRET).
PLAID_CLIENT_ID=
PLAID_SECRET=
# Non-secret params — put these in functions/.env (deployed as runtime env):
# sandbox | development | production  (Trial plan uses `development`/`production`)
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Optional webhook URL (the deployed plaidWebhook function)
PLAID_WEBHOOK_URL=

# === Gemini (SERVER ONLY — Cloud Functions) ===
# Secret: `firebase functions:secrets:set GEMINI_API_KEY`
GEMINI_API_KEY=

# === Local pipeline runs ONLY (optional) ===
# The deployed nightlyPipeline uses the function's own service account (ADC) — no
# key needed. Set this base64-encoded service-account JSON only if you want to run
# `npm run pipeline:local` without `gcloud auth application-default login`.
FIREBASE_SERVICE_ACCOUNT_BASE64=
